# =============================================================================
# .gitignore — COPD Journal Project
# =============================================================================

# -----------------------------------------------------------------------------
# DATA DIRECTORY — contains PHI / HIPAA patient data; never commit
# -----------------------------------------------------------------------------
data/

# -----------------------------------------------------------------------------
# MANUSCRIPT — track source + PDF + DOCX, ignore LaTeX aux files
# -----------------------------------------------------------------------------
report/*.aux
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
report/*.synctex.gz

# -----------------------------------------------------------------------------
# HTML — ignore globally except notebook report
# -----------------------------------------------------------------------------
*.html
!MAL_omics_proteomics.html

# -----------------------------------------------------------------------------
# R ARTIFACTS
# -----------------------------------------------------------------------------
.Rhistory
.RData
*.Rdata
.Rproj.user/

# -----------------------------------------------------------------------------
# JUPYTER ARTIFACTS
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# MACOS SYSTEM FILES
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store

# -----------------------------------------------------------------------------
# CLAUDE CODE LOCAL SETTINGS
# -----------------------------------------------------------------------------
.claude/
