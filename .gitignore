# =============================================================================
# .gitignore — COPD Journal Project
# =============================================================================

# -----------------------------------------------------------------------------
# DATA DIRECTORY — contains PHI / HIPAA patient data; never commit
# -----------------------------------------------------------------------------
data/

# -----------------------------------------------------------------------------
# GENERATED OUTPUTS — reproducible from notebook
# -----------------------------------------------------------------------------
figures/
results/
string_data/

# -----------------------------------------------------------------------------
# MANUSCRIPT — track source + PDF + DOCX, ignore LaTeX aux files
# -----------------------------------------------------------------------------
manuscript/*.aux
manuscript/*.fdb_latexmk
manuscript/*.fls
manuscript/*.log
manuscript/*.out
manuscript/*.synctex.gz

# -----------------------------------------------------------------------------
# HTML — ignore globally except notebook report
# -----------------------------------------------------------------------------
*.html
!MAL_omics_proteomics.html

# -----------------------------------------------------------------------------
# R ARTIFACTS
# -----------------------------------------------------------------------------
.Rhistory
.RData
*.Rdata
.Rproj.user/

# -----------------------------------------------------------------------------
# JUPYTER ARTIFACTS
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# MACOS SYSTEM FILES
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store

# -----------------------------------------------------------------------------
# CLAUDE CODE LOCAL SETTINGS
# -----------------------------------------------------------------------------
.claude/
